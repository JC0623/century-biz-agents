# LLM API 키
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# 공공데이터포털 (data.go.kr)
PUBLIC_DATA_API_KEY=your_public_data_api_key

# 소상공인시장진흥공단 API
SBIZ_API_KEY=your_sbiz_api_key

# 국토교통부 실거래가 API
MOLIT_API_KEY=your_molit_api_key

# 한국은행 ECOS API
ECOS_API_KEY=your_ecos_api_key

# DART 전자공시 API (금융감독원)
DART_API_KEY=your_dart_api_key

# 기본 설정
DEFAULT_LLM=claude          # claude | openai
DEFAULT_TIMEOUT=8           # MCP 도구 타임아웃 (초)
MIN_CONFIDENCE=0.55         # Fallback 트리거 임계값
LOG_LEVEL=INFO
