# OSI-MAS 환경 변수 설정 파일
# 이 파일을 복사하여 .env 로 저장하고 각 키 값을 입력하세요.
# cp .env.example .env

# ────────────────────────────────────────────
# LLM API 키
# ────────────────────────────────────────────

# Anthropic Claude (리포트 합성에 사용)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (선택 — 미설정 시 Claude 단독 사용)
# https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key

# ────────────────────────────────────────────
# 공공 데이터 API 키 (공공데이터포털 https://www.data.go.kr/)
# ────────────────────────────────────────────

# 소상공인시장진흥공단 — 상권 분석 (MarketTool)
# https://www.data.go.kr/data/15083033/openapi.do
SBIZ_API_KEY=your_sbiz_api_key

# 국토교통부 상업업무용 부동산 실거래가 (RealEstateTool)
# https://www.data.go.kr/data/15058017/openapi.do
MOLIT_API_KEY=your_molit_api_key

# 국토교통부 건축물대장 (RealEstateTool / IndustryTool 공용)
# https://www.data.go.kr/data/15044493/openapi.do
BUILDING_API_KEY=your_building_api_key

# 국토교통부 공장·창고 실거래가 (IndustryTool)
# https://www.data.go.kr/data/15058823/openapi.do
FACTORY_TRADE_API_KEY=your_factory_trade_api_key

# DART 전자공시 — 밸류에이션 벤치마크 (ValuationTool)
# https://opendart.fss.or.kr/
DART_API_KEY=your_dart_api_key

# 한국은행 ECOS — 거시 원가·공급망 (MacroTool)
# https://ecos.bok.or.kr/
ECOS_API_KEY=your_ecos_api_key

# 특허청 KIPRIS — 무형자산·인증 (IPTool)
# https://www.data.go.kr/data/15084756/openapi.do
PUBLIC_DATA_API_KEY=your_public_data_api_key

# ────────────────────────────────────────────
# 지도 API (Phase 3)
# ────────────────────────────────────────────

# 네이버 지도 (Phase 3 — 현재 미사용)
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=

# 카카오 지도 (Phase 3 — 현재 미사용, Naver와 택일)
KAKAO_MAPS_APP_KEY=

# ────────────────────────────────────────────
# 시스템 설정
# ────────────────────────────────────────────

# 기본 LLM 선택
DEFAULT_LLM=claude            # claude | openai

# MCP 도구 타임아웃 (초, 기본값 8)
DEFAULT_TIMEOUT=8

# Fallback 트리거 신뢰도 임계값
MIN_CONFIDENCE=0.55

# FastAPI 서버 포트 (기본값 8000)
API_PORT=8000

# 로그 레벨 (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
